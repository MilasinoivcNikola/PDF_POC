# Copy this file to `.env.local` and fill in your key.
# `.env.local` is gitignored — never commit real secrets.

# --- Deploy surface (commerce PR-03) ---
# Which surface this run is: "operator" (the LOCAL surface — engine, OpenAI key,
# wizard, admin) or "public" (the always-on Vercel storefront, which 404s the
# operator routes and never loads the engine). Defaults to "operator" when unset,
# so local `npm run dev` gets the full app. The public Vercel deploy sets
# DEPLOY_TARGET=public explicitly (see vercel.json). Local dev can leave this unset.
DEPLOY_TARGET=operator

# OpenAI API key, used for AI illustration generation (gpt-image-2).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Supabase (commerce data layer) ---
# Project URL and keys from the Supabase dashboard → Project Settings → API.

# Server-only — never a client bundle. Set on BOTH deploys: the operator (local)
# surface AND the public Vercel surface, whose server-side /api/order route writes
# the pending_payment order + photo (PR-05). "Server-only" is not "operator-only".
# The SERVICE-ROLE key bypasses Row Level Security, so it must NEVER be exposed to
# the browser or committed. Used by the server-only data layer (lib/supabase/server.ts).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...service-role...

# Public, anon-safe values (the NEXT_PUBLIC_ prefix ships them to the browser).
# The anon key is constrained by RLS — it cannot read/write orders. The operator
# ADMIN auth gate (PR-08) uses these (via @supabase/ssr) to sign the operator in and
# read the session — purely the gate, never the data path (order data uses the
# service-role key above). Required on the operator surface for admin login.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...anon...

# --- Lemon Squeezy (Merchant of Record — payment, commerce PR-06) ---
# Server-only SECRETS — set on the surface that takes/confirms payment (the public
# Vercel deploy's /api/checkout + /api/webhooks/lemonsqueezy routes). Never commit
# real values, never log them, never expose via NEXT_PUBLIC_.

# API key for creating hosted checkouts (Settings → API in the LS dashboard).
LEMONSQUEEZY_API_KEY=ls_...

# Your LS store id (numeric). Used as the checkout's store relationship.
LEMONSQUEEZY_STORE_ID=12345

# The webhook signing secret you set when creating the webhook in the LS dashboard.
# The webhook handler HMAC-SHA256s the raw request body with this and rejects any
# request whose X-Signature header doesn't match. A misconfigured (empty) secret
# makes the webhook reject everything rather than accept unsigned traffic.
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# Per-product LS variant ids (NON-SECRET public identifiers). One per book; the env
# key is the catalog productId upper-cased with `-`→`_`. Resolved server-side at
# checkout creation (the client-safe catalog never reads env). Fill these in after
# creating one LS product/variant per book, set to MANUAL FULFILMENT (no auto-
# download — our worker delivers in 24–48h).
LEMONSQUEEZY_VARIANT_STORY_1_BOOK=67890
LEMONSQUEEZY_VARIANT_STORY_2_LETTER=67891
LEMONSQUEEZY_VARIANT_STORY_4_TALK=67892
LEMONSQUEEZY_VARIANT_STORY_5_LETTER_TO=67893
LEMONSQUEEZY_VARIANT_STORY_6_TRIBUTE=67894
LEMONSQUEEZY_VARIANT_STORY_7_WELCOME=67895
LEMONSQUEEZY_VARIANT_STORY_8_ADVENTURE=67896
LEMONSQUEEZY_VARIANT_STORY_9_NEWBABY=67897

# --- Resend (delivery email, commerce PR-09) ---
# When the operator APPROVES an order, the Approve route emails the customer a
# tokenized download link and moves the order `approved → delivered`. These run on
# the OPERATOR (local) surface — that's where Approve happens.

# Server-only SECRET — the Resend API key (resend.com → API Keys). Never commit,
# never log, never expose via NEXT_PUBLIC_.
RESEND_API_KEY=re_...

# The From address the delivery email is sent from (a verified Resend sender/domain).
FROM_EMAIL=Dearbound <hello@dearbound.com>

# NON-SECRET. The absolute base URL of the PUBLIC storefront — used ONLY to build
# the emailed download link (`<PUBLIC_SITE_URL>/download/<token>`). The Approve route
# runs on operator/localhost, so it CANNOT derive the public origin from the request;
# it must read this. Local end-to-end: http://localhost:3000. In production: the
# Vercel domain — https://dearbound.com. Fine to commit a non-secret value.
PUBLIC_SITE_URL=http://localhost:3000
