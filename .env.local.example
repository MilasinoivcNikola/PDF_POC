# Copy this file to `.env.local` and fill in your key.
# `.env.local` is gitignored — never commit real secrets.

# OpenAI API key, used for AI illustration generation (gpt-image-2).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Supabase (commerce data layer) ---
# Project URL and keys from the Supabase dashboard → Project Settings → API.

# Server/operator-only. The SERVICE-ROLE key bypasses Row Level Security, so it
# must NEVER be exposed to the browser or committed. Used by the server-only data
# layer (lib/supabase/server.ts) and never sent to a client bundle.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...service-role...

# Public, anon-safe values (the NEXT_PUBLIC_ prefix ships them to the browser).
# The anon key is constrained by RLS — it cannot read/write orders. These power
# any future public Supabase access; the order data layer uses only the keys above.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...anon...
